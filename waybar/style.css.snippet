#custom-of {
	background-color: transparent;
	min-width: 0;
	padding: 0 6px;
}

#custom-of.of-off {
	color: #565f89;
}

#custom-of.of-teams {
	color: #7dcfff;
}

#custom-of.of-special {
	color: #ff9e64;
}

#custom-of.of-individual {
	color: #9ece6a;
}

#custom-of.of-loading {
	opacity: 0.55;
	font-style: italic;
}
