#!/usr/bin/env python3
"""Watch OpenFront.io public lobbies in the terminal."""

import argparse
import asyncio
import json
import sys

WS_URI = "wss://openfront.io/w0/lobbies"
USER_AGENT = (
    "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
    "(KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36"
)
RECONNECT_DELAY_S = 3

CATEGORIES = (
    ("teams", "team", "Teams"),
    ("special", "special", "Special"),
    ("individual", "ffa", "Individual"),
)


def as_int(value) -> int | None:
    if value is None:
        return None
    try:
        return int(value)
    except (TypeError, ValueError):
        return None


def format_team_count(cfg: dict) -> str:
    raw_teams = cfg.get("playerTeams")
    teams = as_int(raw_teams)
    max_players = as_int(cfg.get("maxPlayers"))
    if teams and max_players:
        return f"{teams}x{max_players // teams}"
    if isinstance(raw_teams, str) and raw_teams.strip():
        return raw_teams.strip()
    if teams:
        return f"{teams} teams"
    return ""


def format_starts_at(starts_at_ms: int | None, server_time_ms: int | None) -> str:
    if not starts_at_ms:
        return "start unknown"
    if server_time_ms:
        if starts_at_ms <= server_time_ms:
            return "live"
        delta_s = (starts_at_ms - server_time_ms) // 1000
        if delta_s < 60:
            return f"in {delta_s}s"
        minutes, seconds = divmod(delta_s, 60)
        return f"in {minutes}:{seconds:02d}"
    return "scheduled"


def describe_lobby(game: dict, server_time_ms: int | None) -> str:
    cfg = game.get("gameConfig", {})
    map_name = cfg.get("gameMap", "Unknown")
    team_info = format_team_count(cfg)
    if team_info:
        detail = f"{map_name} {team_info}"
    else:
        detail = f"{map_name} ({cfg.get('gameMode', '?')})"
    players = game.get("numClients", 0)
    max_players = cfg.get("maxPlayers", "?")
    timing = format_starts_at(game.get("startsAt"), server_time_ms)
    game_id = game.get("gameID", "?")
    return f"{detail} | {players}/{max_players} | {timing} | {game_id}"


def is_visible_lobby(game: dict) -> bool:
    if game.get("numClients", 0) > 0:
        return True
    return as_int(game.get("startsAt")) is not None


def parse_all_lobbies(payload: dict) -> dict[str, list[dict]]:
    games = payload.get("games", {})
    raw = {
        "teams": games.get("team", []),
        "special": games.get("special", []),
        "individual": games.get("ffa", []),
    }
    return {key: [game for game in lobbies if is_visible_lobby(game)] for key, lobbies in raw.items()}


def build_display(all_lobbies: dict[str, list[dict]], server_time_ms: int | None, mode: str | None) -> str:
    lines = ["OpenFront lobbies (Ctrl+C to quit)", ""]
    for cat_mode, _, title in CATEGORIES:
        if mode and cat_mode != mode:
            continue
        lines.append(f"{title}:")
        lobbies = all_lobbies.get(cat_mode, [])
        if lobbies:
            for game in lobbies:
                lines.append(f"  {describe_lobby(game, server_time_ms)}")
        else:
            lines.append("  (none)")
        lines.append("")
    return "\n".join(lines).rstrip()


def lobby_state_key(all_lobbies: dict[str, list[dict]], mode: str | None) -> str:
    selected = {key: all_lobbies[key] for key in all_lobbies if not mode or key == mode}
    return json.dumps(selected, sort_keys=True)


async def watch(args: argparse.Namespace) -> None:
    try:
        import websockets
    except ImportError:
        print("Missing dependency: websockets (pip install websockets)", file=sys.stderr)
        sys.exit(1)

    headers = {"Origin": "https://openfront.io", "User-Agent": USER_AGENT}
    last_state_key: str | None = None
    header_printed = False

    while True:
        try:
            async with websockets.connect(WS_URI, additional_headers=headers) as ws:
                async for raw in ws:
                    payload = json.loads(raw)
                    server_time_ms = payload.get("serverTime")
                    all_lobbies = parse_all_lobbies(payload)
                    state_key = lobby_state_key(all_lobbies, args.mode)
                    if state_key == last_state_key:
                        continue
                    if not args.quiet:
                        if header_printed:
                            sys.stdout.write("\033[2J\033[H")
                        print(build_display(all_lobbies, server_time_ms, args.mode), flush=True)
                        header_printed = True
                    last_state_key = state_key
        except asyncio.CancelledError:
            raise
        except Exception as exc:
            if not args.quiet:
                print(f"\nDisconnected: {exc}. Reconnecting in {RECONNECT_DELAY_S}s...", file=sys.stderr)
            await asyncio.sleep(RECONNECT_DELAY_S)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Watch OpenFront.io public lobbies in the terminal.",
    )
    parser.add_argument(
        "--mode",
        choices=["teams", "special", "individual"],
        help="Only show one lobby category.",
    )
    parser.add_argument(
        "--quiet",
        action="store_true",
        help="Suppress terminal output.",
    )
    args = parser.parse_args()

    try:
        asyncio.run(watch(args))
    except KeyboardInterrupt:
        if not args.quiet:
            print("\nStopped.")


if __name__ == "__main__":
    main()
